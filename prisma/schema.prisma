generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Config {
  guildId BigInt @id

  voice VoiceConfig?
}

model VoiceConfig {
  guildId      BigInt             @id @unique
  enabled      Boolean            @default(true)
  announce     Boolean            @default(true)
  announceMode VoiceAnnounceModes @default(GLOBAL)
  channels     VoiceChannel[]

  config Config @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
}

model VoiceChannel {
  id      BigInt @id
  guildId BigInt

  VoiceConfig VoiceConfig? @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
}

enum VoiceAnnounceModes {
  GLOBAL
  ENABLE
  DISABLE
}

model GuildMetrics {
  guildId         BigInt @id @unique
  voiceCharacters Int
  memberCount     Int    @default(0)
}

model GlobalMetrics {
  id          String    @id @default(cuid())
  date        DateTime? @unique @default(now())
  totalGuilds Int
  totalUsers  Int
}
