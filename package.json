{
  "name": "koala",
  "version": "0.5.1",
  "private": false,
  "license": "MIT",
  "type": "module",
  "main": "build/main.js",
  "scripts": {
    "build": "tsc --project tsconfig.build.json && tscpaths -p tsconfig.build.json -s ./src -o ./build && tsc-esm-fix --target='build'",
    "db:gen": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "dev": "tsx watch src/main.ts",
    "postinstall": "npm run db:gen",
    "start": "node ."
  },
  "dependencies": {
    "@changesets/cli": "^2.30.0",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.1",
    "@discordx/importer": "^1.3.3",
    "@discordx/pagination": "^3.6.0",
    "@discordx/utilities": "^7.0.5",
    "@google-cloud/text-to-speech": "^5.8.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "7.3.0",
    "@snazzah/davey": "^0.1.10",
    "@t3-oss/env-core": "^0.7.3",
    "bullmq": "^5.71.0",
    "discord.js": "^14.25.1",
    "discordx": "^11.13.3",
    "ioredis": "^5.10.0",
    "node-cron": "^4.2.1",
    "sodium-native": "^4.3.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "prettier": "^3.8.1",
    "prisma": "7.3.0",
    "ts-node": "^10.9.2",
    "tsc-esm-fix": "^3.1.2",
    "tscpaths": "^0.0.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
